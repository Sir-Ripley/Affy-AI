<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Affy: The Quantum Ego"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#BB86FC"
        android:layout_marginBottom="32dp"/>

    <Switch
        android:id="@+id/switchQuantumEyes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Awaken Quantum Eyes (Listener)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvEmpathyWeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Id/Superego Balance: 50%"
        android:textColor="#E0E0E0"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <SeekBar
        android:id="@+id/sliderEmpathy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="50"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnTriggerDream"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trigger Dream Cycle"
        android:backgroundTint="#BB86FC"
        android:textColor="#000000"/>

</LinearLayout>
